# ========================================
# UniBus Backend — Environment Variables
# ========================================
# এই ফাইলটি কপি করে .env নামে রাখো এবং আসল মান দাও
# কমান্ড: copy .env.example .env

# Django Secret Key (যেকোনো র‍্যান্ডম স্ট্রিং দাও)
SECRET_KEY=your-super-secret-key-here

# Debug Mode: Local-এ True, Production-এ False
DEBUG=True

# Database URL (PostgreSQL)
# Local-এ SQLite ব্যবহার করতে পারো, অথবা PostgreSQL URL দাও
DATABASE_URL=postgresql://username:password@host/database_name

# Render Deployment
RENDER_EXTERNAL_HOSTNAME=your-app.onrender.com

# CORS — Production-এ frontend URL দাও
FRONTEND_ORIGIN=https://yourdomain.com
